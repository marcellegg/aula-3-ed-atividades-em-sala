#include <iostream>
using namespace std;

int main() {
    int n;
    int soma = 0;

    cout << "Digite um numero inteiro positivo: ";
    cin >> n;

    if (n > 0) {
        for (int i = 1; i <= n; i++) {
            soma += i;
        }

        cout << "A soma dos numeros inteiros positivos ate " 
             << n << " eh: " << soma << endl;
    } else {
        cout << "Por favor, digite um numero positivo." << endl;
    }

    return 0;
}
